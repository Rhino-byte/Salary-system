{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "env": {
    "PYTHONPATH": "."
  },
  "crons": [
    {
      "path": "/api/internal/cron/daily-attendance",
      "schedule": "0 22 * * *"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 120
    }
  }
}
